rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Team chat attachments — must be declared before /uploads/{uid}
    // so "teams" is never treated as a user id.
    match /uploads/teams/{teamId}/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    match /uploads/{uid}/{allPaths=**} {
      allow write: if request.auth != null
        && request.auth.uid == uid
        && uid != 'teams';
      // Community package assets need public read so others can open hosted iframes / covers.
      allow read: if (request.auth != null && request.auth.uid == uid)
        || allPaths[0] == 'community';
    }

    match /results/{uid}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
