rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }
    function noteOwner() {
      return signedIn() && resource.data.user_id == request.auth.uid;
    }
    function noteSharedRead() {
      return resource.data.keys().hasAll(['share'])
        && resource.data.share.enabled == true
        && resource.data.share.token is string
        && resource.data.share.token.size() > 0;
    }
    function noteSharedEdit() {
      return noteSharedRead()
        && resource.data.share.mode == 'edit'
        && signedIn();
    }
    function noteDoc(noteId) {
      return get(/databases/$(database)/documents/notes/$(noteId)).data;
    }
    function noteAclRole(noteId) {
      return get(/databases/$(database)/documents/notes/$(noteId)/acl/$(request.auth.uid)).data.role;
    }
    function noteAclEditor(noteId) {
      return signedIn()
        && exists(/databases/$(database)/documents/notes/$(noteId)/acl/$(request.auth.uid))
        && noteAclRole(noteId) == 'editor';
    }
    function noteAclViewer(noteId) {
      return signedIn()
        && exists(/databases/$(database)/documents/notes/$(noteId)/acl/$(request.auth.uid))
        && (noteAclRole(noteId) == 'editor' || noteAclRole(noteId) == 'viewer');
    }
    function canAccessNote(noteId) {
      return signedIn() && (
        noteDoc(noteId).user_id == request.auth.uid
        || noteAclViewer(noteId)
        || (
          noteDoc(noteId).keys().hasAll(['share'])
          && noteDoc(noteId).share.enabled == true
          && noteDoc(noteId).share.token is string
          && noteDoc(noteId).share.token.size() > 0
        )
      );
    }
    function canEditNoteCollab(noteId) {
      return signedIn() && (
        noteDoc(noteId).user_id == request.auth.uid
        || noteAclEditor(noteId)
        || (
          noteDoc(noteId).keys().hasAll(['share'])
          && noteDoc(noteId).share.enabled == true
          && noteDoc(noteId).share.mode == 'edit'
          && noteDoc(noteId).share.token is string
          && noteDoc(noteId).share.token.size() > 0
        )
      );
    }
    function canCommentOnNote(noteId) {
      return canAccessNote(noteId);
    }

    match /jobs/{jobId} {
      allow create: if signedIn()
                    && request.resource.data.user_id == request.auth.uid;
      allow read, update, delete: if signedIn()
                    && resource.data.user_id == request.auth.uid;
    }

    match /notes/{noteId} {
      allow create: if signedIn()
                    && request.resource.data.user_id == request.auth.uid;
      allow read: if noteOwner() || noteSharedRead() || noteAclViewer(noteId);
      allow update: if noteOwner()
        || noteAclEditor(noteId)
        || (noteSharedEdit()
            && request.resource.data.user_id == resource.data.user_id
            && request.resource.data.share == resource.data.share);
      allow delete: if noteOwner();

      match /versions/{versionId} {
        allow read: if canAccessNote(noteId);
        allow create, delete: if signedIn()
          && get(/databases/$(database)/documents/notes/$(noteId)).data.user_id == request.auth.uid;
      }

      match /acl/{uid} {
        allow read: if canAccessNote(noteId);
        allow create, update, delete: if signedIn()
          && noteDoc(noteId).user_id == request.auth.uid;
      }

      match /ydoc/{docId} {
        allow read: if canAccessNote(noteId);
        allow create, update, delete: if canEditNoteCollab(noteId);
      }

      match /ydoc_updates/{updateId} {
        allow read: if canAccessNote(noteId);
        allow create: if canEditNoteCollab(noteId);
        allow update, delete: if canEditNoteCollab(noteId);
      }

      match /awareness/{uid} {
        allow read: if canAccessNote(noteId);
        allow create, update, delete: if signedIn()
          && request.auth.uid == uid
          && canAccessNote(noteId);
      }

      match /threads/{threadId} {
        allow read, write: if canAccessNote(noteId);

        match /messages/{messageId} {
          allow read, create: if canCommentOnNote(noteId);
          allow update, delete: if canCommentOnNote(noteId)
            && resource.data.author_id == request.auth.uid;
        }
      }

      match /page_log/{entryId} {
        allow read: if canCommentOnNote(noteId);
        allow create: if canCommentOnNote(noteId)
          && request.resource.data.uid == request.auth.uid;
        allow update, delete: if canCommentOnNote(noteId)
          && resource.data.uid == request.auth.uid;
      }
    }

    match /share_tokens/{token} {
      allow read: if true;
      allow create, update: if signedIn()
        && request.resource.data.owner_id == request.auth.uid;
      allow delete: if signedIn()
        && resource.data.owner_id == request.auth.uid;
    }

    match /databases/{dbId} {
      allow create: if signedIn()
        && request.resource.data.user_id == request.auth.uid;
      allow read, update, delete: if signedIn()
        && resource.data.user_id == request.auth.uid;
    }

    function isAccessAllowlisted() {
      return signedIn() && (
        request.auth.token.email == 'lcy101120@gmail.com'
        || request.auth.token.email == 'lingyu1122@gmail.com'
        || request.auth.token.email == 'ljc123@gmail.com'
      );
    }

    // Closed-beta access applications
    match /access_requests/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || isAccessAllowlisted());
      allow create: if signedIn() && request.auth.uid == uid
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.keys().hasAll([
          'uid', 'email', 'display_name', 'username', 'status'
        ])
        && (
          (request.resource.data.status == 'pending')
          || (request.resource.data.status == 'approved' && isAccessAllowlisted())
        );
      allow update: if signedIn() && (
        isAccessAllowlisted()
        || (
          request.auth.uid == uid
          && resource.data.status == 'pending'
          && request.resource.data.status == 'pending'
        )
      );
      allow delete: if isAccessAllowlisted();
    }

    // Public profile fields (display name / username / avatar) for signed-in users
    match /users/{uid} {
      allow read: if signedIn();
      allow create, update: if signedIn() && request.auth.uid == uid
        && request.resource.data.keys().hasAll(['display_name', 'username', 'photo_url'])
        && request.resource.data.display_name is string
        && request.resource.data.display_name.size() > 0
        && request.resource.data.display_name.size() <= 40
        && request.resource.data.username is string
        && request.resource.data.username.size() <= 20
        && request.resource.data.photo_url is string;
      allow delete: if signedIn() && request.auth.uid == uid;
    }

    // Unique username claims: usernames/{username} -> { uid }
    match /usernames/{uname} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && uname.matches('^[a-z][a-z0-9_]{2,19}$');
      allow update: if signedIn()
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid;
      allow delete: if signedIn() && resource.data.uid == request.auth.uid;
    }

    match /users/{uid}/workspace/{docId} {
      allow read, write: if signedIn() && request.auth.uid == uid;
    }

    match /users/{uid}/boards/{boardId} {
      allow read, write: if signedIn() && request.auth.uid == uid;
    }

    match /users/{uid}/canvases/{canvasId} {
      allow read, write: if signedIn() && request.auth.uid == uid;
    }

    match /users/{uid}/graphs/{graphId} {
      allow read, write: if signedIn() && request.auth.uid == uid;
    }

    match /users/{uid}/community_extensions/{extId} {
      allow read, write: if signedIn() && request.auth.uid == uid;
    }

    match /users/{uid}/community_templates/{tplId} {
      allow read, write: if signedIn() && request.auth.uid == uid;
    }

    match /users/{uid}/community_ratings/{pkgId} {
      allow read, write: if signedIn() && request.auth.uid == uid;
    }

    match /users/{uid}/community_reports/{pkgId} {
      allow read, write: if signedIn() && request.auth.uid == uid;
    }

    // Anonymous product feedback (sidebar). Create for anyone signed-in;
    // identity fields are for moderation only — UI never displays them.
    match /anonymous_feedback/{id} {
      allow create: if signedIn()
        && request.resource.data.keys().hasAll(['message', 'createdAt', 'clientAt'])
        && request.resource.data.message is string
        && request.resource.data.message.size() >= 2
        && request.resource.data.message.size() <= 2000
        && (!('uid' in request.resource.data)
            || request.resource.data.uid == null
            || request.resource.data.uid == request.auth.uid)
        && (!('path' in request.resource.data)
            || request.resource.data.path is string)
        && (!('include_email' in request.resource.data)
            || request.resource.data.include_email is bool)
        && (!('email' in request.resource.data)
            || request.resource.data.email == null
            || (request.resource.data.email is string
                && request.resource.data.email.size() <= 200));
      allow read, update, delete: if isAccessAllowlisted();
    }

    // Public community store listings (user-published packages)
    match /community_packages/{packageId} {
      allow read: if resource.data.status == 'published'
        || (signedIn() && resource.data.authorUid == request.auth.uid);
      allow create: if signedIn()
        && request.resource.data.authorUid == request.auth.uid
        && request.resource.data.status == 'published'
        && request.resource.data.id == packageId
        && request.resource.data.keys().hasAll([
          'id', 'kind', 'name', 'description', 'author', 'authorUid',
          'version', 'status', 'source', 'manifest', 'createdAt', 'updatedAt'
        ]);
      allow update: if signedIn()
        && resource.data.authorUid == request.auth.uid
        && request.resource.data.authorUid == resource.data.authorUid
        && request.resource.data.id == resource.data.id;
      allow delete: if signedIn() && resource.data.authorUid == request.auth.uid;
    }

    // ─── Team Space ─────────────────────────────────────────
    function isTeamMember(teamId) {
      return signedIn()
        && exists(/databases/$(database)/documents/teams/$(teamId)/members/$(request.auth.uid));
    }
    function teamRole(teamId) {
      return get(/databases/$(database)/documents/teams/$(teamId)/members/$(request.auth.uid)).data.role;
    }
    function isTeamAdmin(teamId) {
      return isTeamMember(teamId) && (teamRole(teamId) == 'owner' || teamRole(teamId) == 'admin');
    }
    function channelData(teamId, channelId) {
      return get(/databases/$(database)/documents/teams/$(teamId)/channels/$(channelId)).data;
    }
    function canAccessChannel(teamId, channelId) {
      let d = channelData(teamId, channelId);
      return isTeamMember(teamId) && (
        d.is_private != true
        || d.created_by == request.auth.uid
        || (d.keys().hasAll(['member_ids']) && request.auth.uid in d.member_ids)
      );
    }

    function isTeamCreator(teamId) {
      return signedIn()
        && exists(/databases/$(database)/documents/teams/$(teamId))
        && get(/databases/$(database)/documents/teams/$(teamId)).data.created_by == request.auth.uid;
    }
    function validPendingInvite(token, teamId, role) {
      return exists(/databases/$(database)/documents/invites/$(token))
        && get(/databases/$(database)/documents/invites/$(token)).data.team_id == teamId
        && get(/databases/$(database)/documents/invites/$(token)).data.status == 'pending'
        && get(/databases/$(database)/documents/invites/$(token)).data.role == role
        && get(/databases/$(database)/documents/invites/$(token)).data.expires_at > request.time;
    }

    match /teams/{teamId} {
      allow create: if signedIn()
        && request.resource.data.created_by == request.auth.uid
        && request.resource.data.keys().hasAll(['name', 'created_by', 'created_at']);
      allow read: if isTeamMember(teamId) || isTeamCreator(teamId);
      allow update, delete: if isTeamAdmin(teamId);

      match /members/{memberId} {
        allow read: if isTeamMember(teamId) || isTeamCreator(teamId);
        // Owner bootstrap (after team doc exists) OR join via pending invite token.
        allow create: if signedIn() && request.auth.uid == memberId
          && (
            (request.resource.data.role == 'owner' && isTeamCreator(teamId))
            || (
              request.resource.data.role in ['admin', 'member', 'guest']
              && request.resource.data.keys().hasAll(['invite_token'])
              && validPendingInvite(
                request.resource.data.invite_token,
                teamId,
                request.resource.data.role
              )
            )
          );
        allow update: if isTeamAdmin(teamId)
          || (signedIn() && request.auth.uid == memberId
              && request.resource.data.diff(resource.data).affectedKeys()
                   .hasOnly(['display_name', 'photo_url', 'status']));
        allow delete: if isTeamAdmin(teamId) || request.auth.uid == memberId;
      }

      match /meta/{docId} {
        allow read, write: if isTeamMember(teamId);
      }

      match /channels/{channelId} {
        // Metadata readable by all members so list queries work; client filters private.
        // Message content is gated by canAccessChannel.
        allow read: if isTeamMember(teamId) || isTeamCreator(teamId);
        // Team creator may seed the default channel during bootstrap.
        allow create: if isTeamMember(teamId) || isTeamCreator(teamId);
        allow update: if isTeamMember(teamId);
        allow delete: if isTeamAdmin(teamId);

        match /messages/{messageId} {
          allow read: if canAccessChannel(teamId, channelId);
          allow create: if canAccessChannel(teamId, channelId)
            && request.resource.data.author_id == request.auth.uid;
          allow update: if canAccessChannel(teamId, channelId)
            && (
              resource.data.author_id == request.auth.uid
              || isTeamAdmin(teamId)
              || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions'])
              || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pinned'])
            );
          allow delete: if canAccessChannel(teamId, channelId)
            && (resource.data.author_id == request.auth.uid || isTeamAdmin(teamId));
        }

        match /typing/{typerId} {
          allow read: if canAccessChannel(teamId, channelId);
          allow write: if canAccessChannel(teamId, channelId)
            && request.auth.uid == typerId;
        }

        match /presence/{uid} {
          allow read: if canAccessChannel(teamId, channelId);
          allow write: if canAccessChannel(teamId, channelId)
            && request.auth.uid == uid;
        }
      }

      match /pins/{pinId} {
        allow read, create, delete: if isTeamMember(teamId);
        allow update: if isTeamMember(teamId);
      }

      match /activity/{activityId} {
        allow read: if isTeamMember(teamId);
        allow create: if isTeamMember(teamId);
      }

      match /tasks/{taskId} {
        allow read, create, update, delete: if isTeamMember(teamId);
      }

      match /standups/{dateKey}/entries/{entryUid} {
        allow read: if isTeamMember(teamId);
        allow create, update: if isTeamMember(teamId)
          && request.auth.uid == entryUid;
        allow delete: if isTeamMember(teamId)
          && (request.auth.uid == entryUid || isTeamAdmin(teamId));
      }
    }

    match /invites/{token} {
      allow read: if true;
      allow create: if signedIn()
        && request.resource.data.created_by == request.auth.uid
        && isTeamAdmin(request.resource.data.team_id);
      allow update: if signedIn()
        && (resource.data.status == 'pending' || isTeamAdmin(resource.data.team_id));
      allow delete: if signedIn() && isTeamAdmin(resource.data.team_id);
    }

    match /users/{uid}/schedule_events/{eventId} {
      allow read, write: if signedIn() && request.auth.uid == uid;
    }

    match /users/{uid}/meeting_sessions/{sessionId} {
      allow read, write: if signedIn() && request.auth.uid == uid;
    }

    match /users/{uid}/integrations/{integrationId} {
      allow read, write: if signedIn() && request.auth.uid == uid;
    }

    match /users/{uid}/teams/{teamId} {
      allow read, write: if signedIn() && request.auth.uid == uid;

      match /reads/{channelId} {
        allow read, write: if signedIn() && request.auth.uid == uid;
      }
    }

    match /users/{uid}/notifications/{notifId} {
      allow read, update, delete: if signedIn() && request.auth.uid == uid;
      allow create: if signedIn();
    }

    // ─── Live cursor presence on note pages ──────────────────
    match /note_presence/{noteId}/users/{uid} {
      allow read: if signedIn();
      allow write: if signedIn() && request.auth.uid == uid;
    }

    // ─── Huddle signaling (offer/answer/candidates) ──────────
    match /huddles/{noteId}/signals/{signalId} {
      allow read, create: if signedIn();
      allow update, delete: if signedIn() && resource.data.from_uid == request.auth.uid;
    }
  }
}
